# Copy this file to .env.local (which is gitignored) and fill in the values.
# Never commit .env.local — it contains secrets.

# Tradier developer token. Get one at https://developer.tradier.com.
# Default environment is "sandbox"; set to "production" only with a funded
# Tradier brokerage account.
VITE_TRADIER_TOKEN=
VITE_TRADIER_ENV=sandbox

# Polygon.io options token (paid Starter tier). Optional alternative to Tradier.
VITE_POLYGON_TOKEN=

# Backend cache server URL. Defaults to http://127.0.0.1:8787 if unset.
# VITE_ORACLE_BACKEND_URL=http://127.0.0.1:8787
